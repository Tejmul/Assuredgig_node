NODE_ENV=development
PORT=8000

# Postgres connection string for Prisma
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/assuredgig?schema=assuredgig_node"

# JWT
JWT_ACCESS_SECRET="dev-access-secret"
JWT_REFRESH_SECRET="dev-refresh-secret"
JWT_ACCESS_TTL_SECONDS=3600
JWT_REFRESH_TTL_SECONDS=86400

# App URLs
FRONTEND_BASE_URL="http://localhost:3000"

# Email (optional; only needed for OTP sending)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
FROM_EMAIL="no-reply@assuredgig.local"
